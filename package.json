{
  "name": "portfolio-mern-stack",
  "version": "1.0.0",
  "description": "Static portfolio website with a lightweight Express host",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "install-server": "cd server && npm ci --no-audit --no-fund",
    "install-client": "cd client && npm ci --legacy-peer-deps --no-audit --no-fund",
    "install-all": "npm run install-server && npm run install-client",
    "build": "cd client && npm run build",
    "heroku-postbuild": "npm run install-all && npm run build"
  },
  "keywords": [
    "portfolio",
    "react",
    "nodejs",
    "express"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  }
}
